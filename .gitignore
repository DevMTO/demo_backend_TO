# =============================================================================
# Backend - Tour Operator - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target
**/target/
**/*.rs.bk
Cargo.lock

# -----------------------------------------------------------------------------
# IDE / Editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Variables de entorno y secretos
# -----------------------------------------------------------------------------
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env
!.env.example

# Secrets
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Docker y Contenedores
# -----------------------------------------------------------------------------
docker-compose.yml
docker-compose.yaml
docker-compose.local.yml
docker-compose.local.yaml
docker-compose.override.yml
docker-compose.override.yaml
docker-compose.prod.yml
docker-compose.production.yml
Dockerfile
Dockerfile.*
!Dockerfile.example
.docker/
.dockerignore

# -----------------------------------------------------------------------------
# Fly.io Deployment
# -----------------------------------------------------------------------------
fly.toml
fly.*.toml
.fly/

# -----------------------------------------------------------------------------
# Otros despliegues / Cloud
# -----------------------------------------------------------------------------
# Railway
railway.toml
railway.json

# Render
render.yaml

# Heroku
Procfile

# Kubernetes
k8s/
kubernetes/
*.yaml
!**/migrations/**/*.yaml

# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# -----------------------------------------------------------------------------
# Logs y archivos temporales
# -----------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
coverage/
*.lcov
tarpaulin-report.html
.coverage

# -----------------------------------------------------------------------------
# Base de datos local
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/
postgres_data/

# -----------------------------------------------------------------------------
# Documentación (excluida del repo)
# -----------------------------------------------------------------------------
docs/
/doc

# -----------------------------------------------------------------------------
# Migraciones sensibles (solo incluir templates)
# -----------------------------------------------------------------------------
# Las migraciones deben estar en el repo
# Pero no datos de seed sensibles
seeds/
seed_data/

# -----------------------------------------------------------------------------
# Binarios y archivos compilados
# -----------------------------------------------------------------------------
*.exe
*.dll
*.so
*.dylib

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
*.bak
*.backup
backups/

# -----------------------------------------------------------------------------
# TypeScript types generados (se regeneran)
# -----------------------------------------------------------------------------
# Los tipos ts-rs se generan, pero los incluimos en el repo
# para que el frontend pueda usarlos sin compilar el backend
# ts_bindings/
