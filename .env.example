# ===========================================
# Backend Tour Operator - Environment Variables
# ===========================================
# Copiar este archivo a .env y configurar los valores

# Server Configuration
HOST=127.0.0.1
PORT=8080
RUST_LOG=secure_auth_api=info,tower_http=warn

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tour_operator_db
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECTION_TIMEOUT=30

# Session Configuration
# Debe tener al menos 64 caracteres
SESSION_SECRET=your_super_secret_session_key_change_in_production_min_64_chars_here
SESSION_EXPIRATION_HOURS=24
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ROTATION_INTERVAL_MINUTES=15

# Cookie Settings
COOKIE_NAME=__Secure-SessionId
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=localhost
COOKIE_PATH=/
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE_HOURS=24

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_MAX_AGE_SECS=3600
CORS_ALLOW_CREDENTIALS=true

# Security - Argon2 (Password Hashing)
ARGON2_MEMORY_SIZE=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=30

# Brute Force Protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Request Limits
MAX_REQUEST_BODY_SIZE=1048576
REQUEST_TIMEOUT_SECS=30
