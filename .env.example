# ===========================================
# Secure Auth API - Environment Variables
# ===========================================

# Server Configuration
HOST=127.0.0.1
PORT=8080
RUST_LOG=debug,tower_http=debug,axum=trace

# =========================
# DATABASE CONFIGURATION
# =========================
DATABASE_URL=postgresql://postgres:123456789@localhost:5432/tour_operator_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tour_operator_db
DATABASE_USER=postgres
DATABASE_PASSWORD=123456789
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECTION_TIMEOUT=30

# =========================
# SESSION CONFIGURATION (Cookies Ultra-Seguras)
# =========================
SESSION_SECRET=ultra_secure_session_secret_key_must_be_at_least_64_characters_long_for_production_use_change_me
SESSION_EXPIRATION_HOURS=24
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ROTATION_INTERVAL_MINUTES=15

# Cookie Settings
# IMPORTANTE: En desarrollo local (HTTP) no usar prefijo __Secure-
# En producción (HTTPS) cambiar a __Secure-SessionId
COOKIE_NAME=SessionId
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=localhost
COOKIE_PATH=/
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE_HOURS=24

# =========================
# CORS CONFIGURATION
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_MAX_AGE_SECS=3600
CORS_ALLOW_CREDENTIALS=true

# =========================
# SECURITY CONFIGURATION
# =========================
# Argon2 password hashing
ARGON2_MEMORY_SIZE=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# Rate Limiting (usando Governor)
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=30

# Brute Force Protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Request limits
MAX_REQUEST_BODY_SIZE=1048576
REQUEST_TIMEOUT_SECS=30
