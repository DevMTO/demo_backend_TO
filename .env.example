# ===========================================
# Secure Auth API - Environment Variables
# ===========================================
# 
# ⚠️  CONFIGURACIÓN DE DESARROLLO
# Para producción, revisar la sección PRODUCTION CHECKLIST al final
# 
# ===========================================

# Server Configuration
HOST=127.0.0.1
PORT=8080
# ⚠️ PRODUCCIÓN: Cambiar a RUST_LOG=info,tower_http=info
RUST_LOG=debug,tower_http=debug,axum=trace

# =========================
# DATABASE CONFIGURATION
# =========================
# ⚠️ PRODUCCIÓN: Usar credenciales seguras y conexión SSL
DATABASE_URL=postgresql://postgres:123456789@localhost:5432/tour_operator_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tour_operator_db
DATABASE_USER=postgres
# ⚠️ PRODUCCIÓN: Usar contraseña segura (mínimo 32 caracteres aleatorios)
DATABASE_PASSWORD=123456789
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECTION_TIMEOUT=30

# =========================
# SESSION CONFIGURATION (Cookies Ultra-Seguras)
# =========================
# ⚠️ PRODUCCIÓN: Generar con: openssl rand -base64 64
SESSION_SECRET=ultra_secure_session_secret_key_must_be_at_least_64_characters_long_for_production_use_change_me
SESSION_EXPIRATION_HOURS=24
SESSION_ROTATION_INTERVAL_MINUTES=60

# Cookie Settings
# ⚠️ PRODUCCIÓN: Cambiar a __Secure-SessionId (requiere HTTPS)
COOKIE_NAME=SessionId
# ⚠️ PRODUCCIÓN: Cambiar a true (requiere HTTPS)
COOKIE_SECURE=false
# ⚠️ PRODUCCIÓN: Cambiar a strict si el frontend está en el mismo dominio
COOKIE_SAME_SITE=lax
# ⚠️ PRODUCCIÓN: Poner el dominio real (ej: .midominio.com)
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE_HOURS=24

# =========================
# CORS CONFIGURATION
# =========================
# ⚠️ PRODUCCIÓN: Cambiar a la URL real del frontend (ej: https://midominio.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_MAX_AGE_SECS=3600
CORS_ALLOW_CREDENTIALS=true

# =========================
# SECURITY CONFIGURATION
# =========================
# Argon2 password hashing (valores seguros para producción)
ARGON2_MEMORY_SIZE=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# Rate Limiting (usando Governor)
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=30

# Brute Force Protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Request limits
MAX_REQUEST_BODY_SIZE=1048576
REQUEST_TIMEOUT_SECS=30

# =========================
# TIGRIS OBJECT STORAGE (S3-Compatible)
# =========================
# Tigris es el storage S3-compatible de Fly.io
# Se usa para almacenar logos, banners e imágenes de agencias
TIGRIS_ACCESS_KEY=tid_ZKFFnRQVGAsKxdEgGRBKYuyUwVnuGMQiwcUbDANfqqVmwMiToy
TIGRIS_SECRET_KEY=tsec_w5e5juBz+GUMAHgOfBgjvrfEyFE7szSF+7AKwgiEey_NzE+3KbQhQugSci7uqvqCLjy5Lg
TIGRIS_BUCKET=magicexperiencesstorage
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev
# Prefijo para archivos de este proyecto (para separar de otros)
TIGRIS_PREFIX=tour-operator

# ===========================================
# ⚠️ PRODUCTION CHECKLIST
# ===========================================
# Antes de desplegar a producción, verificar:
#
# 1. SESSION_SECRET: Generar nuevo secreto (openssl rand -base64 64)
# 2. DATABASE_PASSWORD: Usar contraseña segura
# 3. DATABASE_URL: Usar SSL (añadir ?sslmode=require)
# 4. COOKIE_NAME: Cambiar a __Secure-SessionId
# 5. COOKIE_SECURE: Cambiar a true
# 6. COOKIE_SAME_SITE: Cambiar a strict (mismo dominio) o none (cross-origin HTTPS)
# 7. COOKIE_DOMAIN: Poner dominio real con prefijo . (ej: .midominio.com)
# 8. CORS_ALLOWED_ORIGINS: Poner URL real del frontend
# 9. RUST_LOG: Cambiar a info o warn para reducir logs
# 10. HOST: Cambiar a 0.0.0.0 si se usa en contenedor
#
# Configuración recomendada para producción HTTPS:
# COOKIE_NAME=__Secure-SessionId
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict
# COOKIE_DOMAIN=.midominio.com
# ===========================================
